---
import MoonIcon from "./icons/MoonIcon.astro";
import SunIcon from "./icons/SunIcon.astro";
import HeadsetIcon from "./icons/HeadsetIcon.astro";
import LayersIcon from "./icons/LayersIcon.astro";
import QuestionIcon from "./icons/QuestionIcon.astro";
---

<nav class="side-nav">
  <div class="nav-item">
    <a href="#" class="nav-link theme-toggle">
      <span class="icon-moon"><MoonIcon /></span>
      <span class="icon-sun"><SunIcon /></span>
    </a>
    <span class="tooltip" data-default="شب" data-hover="روز"></span>
  </div>

  <div class="nav-item">
    <a href="#" class="nav-link">
      <HeadsetIcon />
    </a>
    <span class="tooltip">تماس با ما</span>
  </div>

  <div class="nav-item nav-bottom">
    <a href="https://mohajercul.vercel.app/" target="_blank" rel="noopener noreferrer" class="nav-link">
      <LayersIcon />
    </a>
    <span class="tooltip">پروژه‌های دیگر</span>
  </div>

  <div class="nav-item">
    <a href="#" class="nav-link about-toggle">
      <QuestionIcon />
    </a>
    <span class="tooltip">درباره دانشنامه</span>
  </div>
</nav>

<style lang="scss">
  .side-nav {
    position: fixed;
    left: 0;
    top: 0;
    width: 60px;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.35rem;
    z-index: 10;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;

    @media (max-width: 768px) {
      display: none;
    }
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-bottom {
    margin-top: auto;
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    color: var(--color-gold);
    text-decoration: none;
    transition: background 0.2s;

    &:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    :global(svg) {
      display: block;
    }
  }

  // ── Theme toggle: moon default, sun on hover ──
  .icon-sun {
    display: none;
  }

  .theme-toggle:hover {
    .icon-moon {
      display: none;
    }
    .icon-sun {
      display: block;
    }
  }

  // ── Tooltip ──
  .nav-item .tooltip {
    position: absolute;
    left: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%);
    white-space: nowrap;
    background: var(--color-gold);
    color: var(--color-crimson);
    font-size: 0.8rem;
    padding: 4px 10px;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;

    // Arrow pointing left (toward the icon)
    &::after {
      content: "";
      position: absolute;
      left: -6px;
      top: 50%;
      transform: translateY(-50%);
      border-top: 6px solid transparent;
      border-bottom: 6px solid transparent;
      border-right: 6px solid var(--color-gold);
    }
  }

  .nav-item:hover .tooltip {
    opacity: 1;
  }

  // Tooltip text swap on hover (for theme toggle)
  .nav-item .tooltip::before {
    content: attr(data-default);
  }

  .nav-item:hover .tooltip::before {
    content: attr(data-hover);
  }
</style>
