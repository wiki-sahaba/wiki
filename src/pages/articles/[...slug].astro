---
import MainLayout from "../../layouts/MainLayout.astro"
import { getCollection, getEntryBySlug } from "astro:content"

export async function getStaticPaths() {
  const articles = await getCollection("articles")
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await article.render()
---

<MainLayout title={`${article.data.title} | دانشنامه صحابه`}>
  <article class="article-page">
    <h1>{article.data.title}</h1>
    <div class="article-meta">
      {article.data.categories?.map((cat) => <span class="tag">{cat}</span>)}
      <time>{article.data.date.toLocaleDateString("fa-IR")}</time>
    </div>
    <div class="article-content">
      <Content />
    </div>
  </article>
</MainLayout>

<style lang="scss">
  .article-page {
    h1 {
      color: var(--color-gold);
      font-size: 1.5rem;
      margin: 0 0 0.5rem;
    }
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;

    time {
      font-size: 0.8rem;
      color: #999;
    }
  }

  .tag {
    font-size: 0.7rem;
    padding: 2px 10px;
    border-radius: 20px;
    background: rgba(212, 175, 55, 0.12);
    color: #a08020;
    font-weight: 500;
  }

  .article-content {
    color: #444;
    font-size: 0.95rem;
    line-height: 1.9;

    h2 {
      color: #222;
      font-size: 1.15rem;
      margin: 1.5rem 0 0.6rem;
    }

    p {
      margin: 0 0 0.8rem;
    }
  }
</style>
