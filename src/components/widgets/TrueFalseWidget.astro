---
import facts from "../../data/true-false.json";
const now = new Date();
const dayOfYear = Math.floor((now - new Date(now.getFullYear(), 0, 0)) / 86400000);
const todayIndex = dayOfYear % facts.length;
const todayFact = facts[todayIndex];
---

<div class="tf-card" id="tf-card" data-facts={JSON.stringify(facts)}>
  <div class="tf-header">
    <div class="tf-icon">⚖️</div>
    <h3 class="tf-title">درست یا نادرست</h3>
  </div>

  <div class="tf-body" id="tf-body">
    <p class="tf-statement" id="tf-statement">{todayFact.statement}</p>
    <div class="tf-buttons">
      <button class="tf-btn tf-true" id="tf-true" data-answer="true">✅ درست</button>
      <button class="tf-btn tf-false" id="tf-false" data-answer="false">❌ نادرست</button>
    </div>
    <div class="tf-result" id="tf-result" style="display:none"></div>
  </div>

  <div class="tf-nav">
    <button class="tf-nav-btn" id="tf-prev">‹ قبلی</button>
    <span class="tf-counter" id="tf-counter">{todayIndex + 1} / {facts.length}</span>
    <button class="tf-nav-btn" id="tf-next">بعدی ›</button>
  </div>
</div>

<script src="../../scripts/true-false.ts"></script>

<style lang="scss">
  .tf-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem 1.75rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .tf-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tf-icon { font-size: 1.3rem; }
  .tf-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-crimson);
    margin: 0;
  }

  .tf-statement {
    font-size: 0.92rem;
    font-weight: 500;
    color: #333;
    line-height: 1.7;
    margin-bottom: 1rem;
    min-height: 3em;
  }

  .tf-buttons {
    display: flex;
    gap: 0.6rem;
  }

  .tf-btn {
    flex: 1;
    padding: 0.65rem;
    border: 2px solid #eee;
    border-radius: 12px;
    font-size: 0.85rem;
    font-family: 'Vazirmatn', sans-serif;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
    background: #fafafa;
    color: #333;

    &:hover:not(:disabled) {
      border-color: var(--color-gold);
      background: #fffbf0;
    }
    &:disabled { cursor: default; opacity: 0.85; }
    &.correct {
      border-color: #2ecc71;
      background: #e8f8f0;
      color: #1a7a42;
    }
    &.wrong {
      border-color: #e74c3c;
      background: #fde8e8;
      color: #b03a2e;
    }
  }

  .tf-result {
    margin-top: 0.7rem;
    padding: 0.6rem 1rem;
    border-radius: 10px;
    background: #f8f8f8;
    font-size: 0.82rem;
    color: #444;
    line-height: 1.6;
  }

  .tf-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    padding-top: 0.8rem;
    border-top: 1px solid #f0f0f0;
  }

  .tf-nav-btn {
    background: none;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-family: 'Vazirmatn', sans-serif;
    color: #666;
    cursor: pointer;
    transition: all 0.2s;
    &:hover {
      border-color: var(--color-gold);
      color: var(--color-crimson);
    }
  }

  .tf-counter {
    font-size: 0.78rem;
    color: #999;
    font-weight: 500;
  }
</style>
