---
export interface Props {
  references: {
    title: string;
    author?: string;
    year?: string;
    publisher?: string;
  }[];
}

const { references } = Astro.props;
---

{references.length > 0 && (
  <section class="references">
    <div class="references-header">
      <div class="references-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      </div>
      <h2>منابع و مراجع</h2>
    </div>
    <div class="references-grid">
      {references.map((ref, i) => (
        <div class="ref-card">
          <div class="ref-num">{String(i + 1).padStart(2, '۰')}</div>
          <div class="ref-info">
            <div class="ref-title">{ref.title}</div>
            <div class="ref-meta">
              {ref.author && <span>{ref.author}</span>}
              {ref.year && <span class="ref-sep">·</span>}
              {ref.year && <span>{ref.year}</span>}
              {ref.publisher && <span class="ref-sep">·</span>}
              {ref.publisher && <span>{ref.publisher}</span>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style lang="scss">
  .references {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid rgba(212, 175, 55, 0.15);
  }

  .references-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;

    h2 {
      font-size: 1.1rem;
      font-weight: 700;
      font-family: 'Alexandria', sans-serif;
      color: var(--color-crimson);
      margin: 0;
    }
  }

  .references-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
  }

  .references-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ref-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: rgba(0, 0, 0, 0.015);
    transition: border-color 0.2s, box-shadow 0.2s;

    &:hover {
      border-color: rgba(212, 175, 55, 0.25);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    }
  }

  .ref-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--color-crimson);
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    font-family: 'Alexandria', sans-serif;
    margin-top: 2px;
  }

  .ref-info {
    flex: 1;
    min-width: 0;
  }

  .ref-title {
    font-weight: 600;
    color: #333;
    font-size: 0.88rem;
    line-height: 1.5;
    margin-bottom: 3px;
  }

  .ref-meta {
    font-size: 0.76rem;
    color: #999;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
  }

  .ref-sep {
    color: #ccc;
  }
</style>
