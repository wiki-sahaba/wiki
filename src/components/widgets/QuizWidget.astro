---
import questions from "../../data/questions.json";
const now = new Date();
const dayOfYear = Math.floor((now - new Date(now.getFullYear(), 0, 0)) / 86400000);
const todayIndex = dayOfYear % questions.length;
const todayQuestion = questions[todayIndex];
---

<div class="quiz-card" id="quiz-card" data-questions={JSON.stringify(questions)}>
  <div class="quiz-header">
    <div class="quiz-icon">❓</div>
    <h3 class="quiz-title">سوال روز</h3>
  </div>

  <div class="quiz-body" id="quiz-body">
    <p class="quiz-question" id="quiz-question">{todayQuestion.question}</p>
    <div class="quiz-options" id="quiz-options">
      {todayQuestion.options.map((opt, i) => (
        <button class="quiz-option" data-index={i}>{opt}</button>
      ))}
    </div>
    <div class="quiz-result" id="quiz-result" style="display:none"></div>
  </div>

  <div class="quiz-nav">
    <button class="quiz-nav-btn" id="prev-btn">‹ قبلی</button>
    <span class="quiz-counter" id="quiz-counter">{todayIndex + 1} / {questions.length}</span>
    <button class="quiz-nav-btn" id="next-btn">بعدی ›</button>
  </div>
</div>

<script src="../../scripts/quiz.ts"></script>

<style lang="scss">
  .quiz-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem 1.75rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .quiz-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .quiz-icon {
    font-size: 1.3rem;
  }

  .quiz-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-crimson);
    margin: 0;
  }

  .quiz-question {
    font-size: 0.92rem;
    font-weight: 500;
    color: #333;
    line-height: 1.6;
    margin-bottom: 1rem;
    min-height: 3em;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .quiz-option {
    width: 100%;
    padding: 0.7rem 1rem;
    border: 2px solid #eee;
    border-radius: 12px;
    background: #fafafa;
    color: #333;
    font-size: 0.85rem;
    font-family: 'Vazirmatn', sans-serif;
    cursor: pointer;
    text-align: right;
    transition: all 0.2s;

    &:hover:not(:disabled) {
      border-color: var(--color-gold);
      background: #fffbf0;
    }

    &.correct {
      border-color: #2ecc71;
      background: #e8f8f0;
      color: #1a7a42;
    }

    &.wrong {
      border-color: #e74c3c;
      background: #fde8e8;
      color: #b03a2e;
    }

    &:disabled {
      cursor: default;
      opacity: 0.85;
    }
  }

  .quiz-result {
    margin-top: 0.8rem;
    padding: 0.7rem 1rem;
    border-radius: 12px;
    background: #f8f8f8;
    font-size: 0.82rem;
    color: #444;
    line-height: 1.6;
  }

  .quiz-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    padding-top: 0.8rem;
    border-top: 1px solid #f0f0f0;
  }

  .quiz-nav-btn {
    background: none;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-family: 'Vazirmatn', sans-serif;
    color: #666;
    cursor: pointer;
    transition: all 0.2s;

    &:hover {
      border-color: var(--color-gold);
      color: var(--color-crimson);
    }
  }

  .quiz-counter {
    font-size: 0.78rem;
    color: #999;
    font-weight: 500;
  }
</style>
