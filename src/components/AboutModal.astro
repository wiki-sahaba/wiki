---
import TelegramIcon from "./icons/social/telegram.svg";
import InstagramIcon from "./icons/social/instagram.svg";
import TiktokIcon from "./icons/social/tiktok.svg";
import XIcon from "./icons/social/x.svg";
---
<div class="about-overlay" id="about-modal">
  <div class="about-modal">
    <button class="about-close" id="about-close">&times;</button>
    <div class="about-header">
      <div class="about-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
      </div>
      <h2 class="about-title">درباره دانشنامه صحابه</h2>
      <p class="about-subtitle">بزرگترین دانشنامه دیجیتالی صحابه پیامبر اکرم (ص)</p>
    </div>

    <div class="about-body">
      <p>
        دانشنامه صحابه یک پروژه جامع و دیجیتال برای ثبت و معرفی صحابه و صحابیات پیامبر اکرم (ص) است. هدف ما ایجاد بزرگترین مرجع فارسی در این حوزه است که شامل زندگی‌نامه، فضایل، روایات و داستان‌های واقعی از زندگی یاران پیامبر باشد.
      </p>
      <p>
        این دانشنامه با بهره‌گیری از منابع معتبر اسلامی و با همکاری پژوهشگران و محققان علوم اسلامی تدوین شده است. ما تلاش می‌کنیم تا با ارائه محتوای دقیق و مستند، گامی مؤثر در شناخت صحابه برداریم و الگوهایی درست از زندگی آنان برای نسل‌های آینده به یادگار بگذاریم.
      </p>
      <p>
        با ما همراه باشید و نظرات، پیشنهادات و انتقادات خود را از طریق شبکه‌های اجتماعی با ما به اشتراک بگذارید. ما معتقدیم که مشارکت جمعی کلید موفقیت این پروژه است.
      </p>
    </div>

    <div class="about-socials">
      <a href="#" class="social-link social-telegram" target="_blank" rel="noopener noreferrer" aria-label="تلگرام">
        <TelegramIcon />
      </a>
      <a href="#" class="social-link social-instagram" target="_blank" rel="noopener noreferrer" aria-label="اینستاگرام">
        <InstagramIcon />
      </a>
      <a href="#" class="social-link social-tiktok" target="_blank" rel="noopener noreferrer" aria-label="تیکتاک">
        <TiktokIcon />
      </a>
      <a href="#" class="social-link social-x" target="_blank" rel="noopener noreferrer" aria-label="X">
        <XIcon />
      </a>
    </div>

    <div class="about-footer">
      <span>نسخه ۱.۰</span>
      <span>© ۱۴۰۵ دانشنامه صحابه</span>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('about-modal');
  const closeBtn = document.getElementById('about-close');

  closeBtn?.addEventListener('click', () => modal?.classList.remove('show'));
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.remove('show');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') modal?.classList.remove('show');
  });
</script>

<style lang="scss">
  .about-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, visibility 0.35s ease;
    backdrop-filter: blur(4px);

    &.show {
      opacity: 1;
      visibility: visible;

      .about-modal {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }
  }

  .about-modal {
    background: #fff;
    border-radius: 24px;
    padding: 2.5rem;
    max-width: 560px;
    width: 90%;
    max-height: 85vh;
    overflow-y: auto;
    position: relative;
    transform: translateY(30px) scale(0.95);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);

    &::-webkit-scrollbar {
      width: 4px;
    }

    &::-webkit-scrollbar-thumb {
      background: rgba(212, 175, 55, 0.3);
      border-radius: 2px;
    }
  }

  .about-close {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.06);
    color: #555;
    font-size: 1.4rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s;

    &:hover {
      background: var(--color-crimson);
      color: #fff;
    }
  }

  .about-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .about-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--color-crimson), #7a1a1a);
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .about-title {
    font-size: 1.3rem;
    font-weight: 700;
    font-family: 'Alexandria', sans-serif;
    color: var(--color-crimson);
    margin-bottom: 0.3rem;
  }

  .about-subtitle {
    font-size: 0.82rem;
    color: #888;
  }

  .about-body {
    p {
      font-size: 0.88rem;
      line-height: 1.9;
      color: #444;
      margin-bottom: 1rem;

      &:last-child {
        margin-bottom: 0;
      }
    }
  }

  .about-socials {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 1.8rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-crimson);
    background: rgba(90, 13, 13, 0.08);
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s, color 0.2s;

    :global(svg) {
      display: block;
    }

    &:hover {
      transform: translateY(-3px);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    }
  }

  .social-telegram {
    &:hover {
      background: #0088cc;
      color: #fff;
    }
  }

  .social-instagram {
    &:hover {
      background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
      color: #fff;
    }
  }

  .social-tiktok {
    &:hover {
      background: #000;
      color: #fff;
    }
  }

  .social-x {
    &:hover {
      background: #000;
      color: #fff;
    }
  }

  .about-footer {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 0.72rem;
    color: #aaa;
  }
</style>
