---
import MainLayout from "../../layouts/MainLayout.astro"
import { getCollection } from "astro:content"

const articles = await getCollection("articles")
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<MainLayout title="مقالات | دانشنامه صحابه">
  <section class="articles-page">
    <h1>مقالات دانشنامه</h1>

    <div class="article-list">
      {articles.map((article) => (
        <a href={`/articles/${article.slug}/`} class="article-card">
          <h2>{article.data.title}</h2>
          {article.data.categories && (
            <div class="tags">
              {article.data.categories.map((cat) => <span class="tag">{cat}</span>)}
            </div>
          )}
          {article.data.description && <p>{article.data.description}</p>}
        </a>
      ))}
    </div>
  </section>
</MainLayout>

<style lang="scss">
  .articles-page {
    h1 {
      color: var(--color-gold);
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
    }
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .article-card {
    display: block;
    padding: 1.25rem 1.5rem;
    border-radius: 14px;
    background: rgba(0, 0, 0, 0.03);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, box-shadow 0.2s;

    &:hover {
      background: rgba(0, 0, 0, 0.05);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    }

    h2 {
      color: #222;
      font-size: 1.1rem;
      margin: 0 0 0.4rem;
    }

    p {
      color: #666;
      font-size: 0.85rem;
      margin: 0;
      line-height: 1.6;
    }
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    padding: 2px 10px;
    border-radius: 20px;
    background: rgba(212, 175, 55, 0.12);
    color: #a08020;
    font-weight: 500;
  }
</style>
