---
export interface Props {
  source?: string;
}

const { source } = Astro.props;
---

<blockquote class="tg-quote">
  <div class="tg-quote-icon">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-5.06 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
    </svg>
  </div>
  <div class="tg-quote-content">
    <slot />
  </div>
  {source && <cite class="tg-quote-source">{source}</cite>}
</blockquote>

<style lang="scss">
  .tg-quote {
    position: relative;
    border-right: 4px solid #0088cc;
    background: rgba(0, 136, 204, 0.04);
    border-radius: 0 12px 12px 0;
    padding: 1rem 1.2rem;
    margin: 1.2rem 0;

    :global(p) {
      margin: 0;
    }
  }

  .tg-quote-icon {
    position: absolute;
    top: 10px;
    left: 12px;
    color: #0088cc;
    opacity: 0.5;
  }

  .tg-quote-content {
    font-size: 0.92rem;
    line-height: 1.8;
    color: #444;
  }

  .tg-quote-source {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.78rem;
    font-style: normal;
    color: #999;
  }
</style>
